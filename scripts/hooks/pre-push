#!/usr/bin/env bash
# pre-push — runs make check before every push.
#
# Install this hook with:
#   make setup-hooks
#
# Skip with:
#   git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

echo "==> Running make check before push (skip with --no-verify)..."
cd "$REPO_ROOT" && make check
