# vibewarden.yaml — VibeWarden Security Sidecar Configuration
# Generated by `vibewarden init`. Edit as needed.
# Full reference: https://vibewarden.dev/docs/config

server:
  host: "127.0.0.1"
  port: 8080

upstream:
  host: "127.0.0.1"
  port: {{ .UpstreamPort }}

log:
  level: "info"
  format: "json"

security_headers:
  enabled: true
  hsts_max_age: 31536000
  hsts_include_subdomains: true
  hsts_preload: false
  content_type_nosniff: true
  frame_option: "SAMEORIGIN"
  content_security_policy: "default-src 'self'"
  referrer_policy: "strict-origin-when-cross-origin"
  permissions_policy: "geolocation=(), microphone=(), camera=()"
{{- if .TLSEnabled }}

tls:
  enabled: true
  provider: "letsencrypt"
  domain: "{{ .TLSDomain }}"
  storage_path: "./data/caddy"
{{- else }}

tls:
  enabled: false
{{- end }}
{{- if .AuthEnabled }}

kratos:
  public_url: "http://localhost:4433"
  admin_url: "http://localhost:4434"

auth:
  session_cookie_name: "ory_kratos_session"
  login_url: "http://localhost:4433/self-service/login/browser"
  public_paths:
    - "/health"
    - "/ready"
{{- end }}
{{- if .RateLimitEnabled }}

rate_limit:
  enabled: true
  trust_proxy_headers: false
  per_ip:
    requests_per_second: 10
    burst: 20
  per_user:
    requests_per_second: 50
    burst: 100
  exempt_paths:
    - "/health"
    - "/ready"
{{- end }}
