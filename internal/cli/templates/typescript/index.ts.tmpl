import express, { Request, Response } from "express";

const app = express();
const port = {{ .Port }};

app.use(express.json());

// health returns a JSON status payload used by the VibeWarden sidecar health check.
app.get("/health", (_req: Request, res: Response) => {
  res.json({ status: "ok" });
});

// root is the application index route.
app.get("/", (_req: Request, res: Response) => {
  res.json({
    service: "{{ .ProjectName }}",
    message:
      "Hello from {{ .ProjectName }}! Edit src/index.ts to get started.",
  });
});

// public is accessible without authentication.
// The VibeWarden sidecar forwards requests here without verifying identity.
app.get("/public", (_req: Request, res: Response) => {
  res.json({
    route: "public",
    message: "This route is accessible without authentication.",
  });
});

// protected requires authentication.
// The VibeWarden sidecar verifies identity and injects headers before forwarding.
app.get("/protected", (req: Request, res: Response) => {
  const userId = req.headers["x-user-id"] ?? "anonymous";
  const userEmail = req.headers["x-user-email"] ?? "";
  res.json({ route: "protected", userId, userEmail });
});

app.listen(port, "0.0.0.0", () => {
  console.log(
    JSON.stringify({
      level: "info",
      msg: "server started",
      port,
      service: "{{ .ProjectName }}",
    })
  );
});
