#!/bin/sh
# vibew — zero-install wrapper for the VibeWarden CLI
# Generated by `vibewarden wrap`. Commit this file so anyone who checks out
# the project can run `./vibew <command>` without a separate install step.
# GITHUB_TOKEN — optional; avoids GitHub API rate limits.
set -e
REPO="vibewarden/vibewarden"
CACHE_DIR="${HOME}/.vibewarden/bin"
VERSION_FILE=".vibewarden-version"
resolve_version() {
    if [ -f "${VERSION_FILE}" ]; then
        tr -d '[:space:]' < "${VERSION_FILE}"
        return
    fi
    if [ -n "${GITHUB_TOKEN}" ]; then
        auth_header="Authorization: Bearer ${GITHUB_TOKEN}"
    else
        auth_header=""
    fi
    url="https://api.github.com/repos/${REPO}/releases/latest"
    if command -v curl >/dev/null 2>&1; then
        if [ -n "${auth_header}" ]; then
            version=$(curl -fsSL -H "${auth_header}" "${url}" | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
        else
            version=$(curl -fsSL "${url}" | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
        fi
    elif command -v wget >/dev/null 2>&1; then
        if [ -n "${auth_header}" ]; then
            version=$(wget -qO- --header="${auth_header}" "${url}" | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
        else
            version=$(wget -qO- "${url}" | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
        fi
    else
        echo "error: curl or wget is required" >&2
        exit 1
    fi
    if [ -z "${version}" ]; then
        echo "error: could not determine latest VibeWarden version" >&2
        exit 1
    fi
    printf '%s' "${version}"
}
detect_platform() {
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    case "${os}" in
        darwin) OS="darwin" ;;
        linux)  OS="linux" ;;
        *)
            echo "error: unsupported OS: ${os}" >&2
            exit 1
        ;;
    esac
    arch=$(uname -m)
    case "${arch}" in
        x86_64|amd64)  ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
        *)
            echo "error: unsupported architecture: ${arch}" >&2
            exit 1
        ;;
    esac
}
download() {
    url="$1"
    dest="$2"
    if command -v curl >/dev/null 2>&1; then
        if [ -n "${GITHUB_TOKEN}" ]; then
            curl -fsSL -H "Authorization: Bearer ${GITHUB_TOKEN}" -o "${dest}" "${url}"
        else
            curl -fsSL -o "${dest}" "${url}"
        fi
    elif command -v wget >/dev/null 2>&1; then
        if [ -n "${GITHUB_TOKEN}" ]; then
            wget -qO "${dest}" --header="Authorization: Bearer ${GITHUB_TOKEN}" "${url}"
        else
            wget -qO "${dest}" "${url}"
        fi
    else
        echo "error: curl or wget is required" >&2
        exit 1
    fi
}
verify_checksum() {
    file="$1"
    checksums="$2"
    filename=$(basename "${file}")
    expected=$(grep " ${filename}$" "${checksums}" | awk '{print $1}')
    if [ -z "${expected}" ]; then
        echo "error: no checksum found for ${filename}" >&2
        exit 1
    fi
    if command -v sha256sum >/dev/null 2>&1; then
        actual=$(sha256sum "${file}" | awk '{print $1}')
    elif command -v shasum >/dev/null 2>&1; then
        actual=$(shasum -a 256 "${file}" | awk '{print $1}')
    else
        echo "error: sha256sum or shasum is required for checksum verification" >&2
        exit 1
    fi
    if [ "${actual}" != "${expected}" ]; then
        echo "error: checksum mismatch for ${filename}" >&2
        echo "  expected: ${expected}" >&2
        echo "  actual:   ${actual}" >&2
        exit 1
    fi
}
detect_platform
VERSION=$(resolve_version)
BINARY_NAME="vibewarden-${VERSION}-${OS}-${ARCH}"
CACHED_BIN="${CACHE_DIR}/${BINARY_NAME}"
if [ ! -x "${CACHED_BIN}" ]; then
    BASE_URL="https://github.com/${REPO}/releases/download/${VERSION}"
    CHECKSUMS_URL="${BASE_URL}/vibewarden-${VERSION}-checksums.txt"
    BINARY_URL="${BASE_URL}/${BINARY_NAME}"
    TMP_DIR=$(mktemp -d)
    trap 'rm -rf "${TMP_DIR}"' EXIT
    echo "Downloading VibeWarden ${VERSION} (${OS}/${ARCH})..." >&2
    download "${BINARY_URL}" "${TMP_DIR}/${BINARY_NAME}"
    download "${CHECKSUMS_URL}" "${TMP_DIR}/checksums.txt"
    verify_checksum "${TMP_DIR}/${BINARY_NAME}" "${TMP_DIR}/checksums.txt"
    mkdir -p "${CACHE_DIR}"
    mv "${TMP_DIR}/${BINARY_NAME}" "${CACHED_BIN}"
    chmod +x "${CACHED_BIN}"
fi
exec "${CACHED_BIN}" "$@"
