@echo off
:: vibew.cmd — thin batch wrapper that calls vibew.ps1
::
:: Generated by `vibewarden wrap`. Commit this file alongside vibew.ps1 so
:: that `vibew <args>` works from CMD and batch scripts on Windows.

setlocal

set "SCRIPT_DIR=%~dp0"

powershell.exe -NoProfile -ExecutionPolicy Bypass -File "%SCRIPT_DIR%vibew.ps1" %*
exit /b %ERRORLEVEL%
