package com.example.{{ .ProjectName }}

import io.ktor.http.*
import io.ktor.serialization.kotlinx.json.*
import io.ktor.server.application.*
import io.ktor.server.engine.*
import io.ktor.server.netty.*
import io.ktor.server.plugins.contentnegotiation.*
import io.ktor.server.response.*
import io.ktor.server.routing.*
import kotlinx.serialization.Serializable

// Application is the entry point for {{ .ProjectName }}.
fun main() {
    embeddedServer(Netty, port = {{ .Port }}, host = "0.0.0.0", module = Application::module)
        .start(wait = true)
}

// module configures the Ktor application with content negotiation and routing.
fun Application.module() {
    install(ContentNegotiation) {
        json()
    }
    configureRouting()
}

// configureRouting registers all application routes.
fun Application.configureRouting() {
    routing {
        get("/health") {
            call.respond(mapOf("status" to "ok"))
        }

        get("/") {
            call.respond(
                RootResponse(
                    service = "{{ .ProjectName }}",
                    message = "Hello from {{ .ProjectName }}! Edit src/main/kotlin/com/example/{{ .ProjectName }}/Application.kt to get started.",
                )
            )
        }

        // Public route — no authentication required.
        // VibeWarden sidecar forwards requests here without verifying identity.
        get("/public") {
            call.respond(mapOf("route" to "public", "message" to "This route is accessible without authentication."))
        }

        // Protected route — authentication handled by the VibeWarden sidecar.
        // Identity headers are injected by the sidecar before the request arrives here.
        get("/protected") {
            val userId = call.request.headers["X-User-Id"] ?: "anonymous"
            val userEmail = call.request.headers["X-User-Email"] ?: ""
            call.respond(
                mapOf(
                    "route" to "protected",
                    "userId" to userId,
                    "userEmail" to userEmail,
                )
            )
        }
    }
}

// RootResponse is the data class returned by the root route.
@Serializable
data class RootResponse(
    val service: String,
    val message: String,
)
