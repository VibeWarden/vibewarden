# docker-compose.yml — Generated by VibeWarden from vibewarden.yaml
# Do not edit manually — re-run `vibewarden generate` to regenerate.
# To customise, set overrides.compose_file in vibewarden.yaml.
#
# Services:
{{- if or .App.Build .App.Image }}
#   app         — Your application
{{- end }}
#   vibewarden  — Security sidecar (listens on :{{ .Server.Port }}, forwards to app on :{{ .Upstream.Port }})
{{- if .Auth.Enabled }}
#   kratos      — Ory Kratos identity server
#   kratos-db   — PostgreSQL for Kratos
{{- end }}
{{- if .Secrets.Enabled }}
#   openbao     — OpenBao secret store
{{- end }}
{{- if and .Secrets.Enabled (or (len .Secrets.Inject.Headers) (len .Secrets.Inject.Env)) }}
#   seed-secrets — One-shot container that seeds demo secrets into OpenBao
{{- end }}
{{- if eq .RateLimit.Store "redis" }}
#   redis       — Redis backing store for rate limiting
{{- end }}
{{- if .Observability.Enabled }}
#   prometheus      — Metrics collection (profile: observability)
#   loki            — Log aggregation (profile: observability)
#   promtail        — Log collector for non-VibeWarden containers (profile: observability)
#   otel-collector  — OTel Collector: receives OTLP from VibeWarden, exports to Prometheus, Loki, and Tempo (profile: observability)
#   tempo           — Distributed tracing backend (profile: observability)
#   grafana         — Visualization (profile: observability)
{{- end }}

version: "3.9"

services:
{{- if or .App.Build .App.Image }}
  app:
    restart: unless-stopped
{{- if .App.Build }}
    build:
      context: {{ .App.Build }}
{{- else if .App.Image }}
    image: ${VIBEWARDEN_APP_IMAGE:-{{ .App.Image }}}
{{- end }}
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD-SHELL", "curl -sf http://localhost:{{ .Upstream.Port }}/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s

{{- end }}
  vibewarden:
    image: ghcr.io/vibewarden/vibewarden:latest
    restart: unless-stopped
    command: ["serve", "--config", "/etc/vibewarden/vibewarden.yaml"]
    ports:
      - "{{ .Server.Port }}:{{ .Server.Port }}"
    volumes:
      - ./vibewarden.yaml:/etc/vibewarden/vibewarden.yaml:ro
{{- if .TLS.Enabled }}
      - vibewarden-data:/var/lib/vibewarden
{{- end }}
{{- if .Secrets.Enabled }}
    env_file:
      - ./.vibewarden/generated/.credentials
{{- end }}
    environment:
{{- if or .App.Build .App.Image }}
      - VIBEWARDEN_UPSTREAM_HOST=app
{{- else }}
      - VIBEWARDEN_UPSTREAM_HOST=host.docker.internal
{{- end }}
      - VIBEWARDEN_UPSTREAM_PORT={{ .Upstream.Port }}
{{- if .Secrets.Enabled }}
      - VIBEWARDEN_SECRETS_OPENBAO_ADDRESS=http://openbao:8200
      - VIBEWARDEN_SECRETS_OPENBAO_AUTH_TOKEN=${OPENBAO_DEV_ROOT_TOKEN}
{{- end }}
{{- if eq .RateLimit.Store "redis" }}
      - VIBEWARDEN_RATE_LIMIT_REDIS_ADDRESS=redis:6379
{{- end }}
{{- if .Observability.Enabled }}
      - VIBEWARDEN_TELEMETRY_OTLP_ENABLED=true
      - VIBEWARDEN_TELEMETRY_OTLP_ENDPOINT=http://otel-collector:4318
      - VIBEWARDEN_TELEMETRY_LOGS_OTLP=true
{{- end }}
{{- if not (or .App.Build .App.Image) }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{{- end }}
    networks:
      - vibewarden
{{- if or .Auth.Enabled .App.Build .App.Image .Secrets.Enabled (eq .RateLimit.Store "redis") }}
    depends_on:
{{- if or .App.Build .App.Image }}
      app:
        condition: service_healthy
{{- end }}
{{- if .Auth.Enabled }}
      kratos:
        condition: service_healthy
{{- end }}
{{- if and .Secrets.Enabled (or (len .Secrets.Inject.Headers) (len .Secrets.Inject.Env)) }}
      seed-secrets:
        condition: service_completed_successfully
{{- else if .Secrets.Enabled }}
      openbao:
        condition: service_healthy
{{- end }}
{{- if eq .RateLimit.Store "redis" }}
      redis:
        condition: service_healthy
{{- end }}
{{- end }}
{{- if .Auth.Enabled }}

  kratos-db:
    image: postgres:17-alpine
    restart: unless-stopped
    env_file:
      - ./.vibewarden/generated/.credentials
    environment:
      POSTGRES_DB: kratos
      POSTGRES_USER: kratos
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - kratos-db-data:/var/lib/postgresql/data
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U kratos"]
      interval: 5s
      timeout: 5s
      retries: 10

  kratos:
    image: oryd/kratos:v1.3.1
    restart: unless-stopped
    command: serve --config /etc/kratos/kratos.yaml --dev
    env_file:
      - ./.vibewarden/generated/.credentials
    environment:
      DSN: "postgres://kratos:${POSTGRES_PASSWORD}@kratos-db:5432/kratos?sslmode=disable"
      SECRETS_COOKIE: "${KRATOS_SECRETS_COOKIE}"
      SECRETS_CIPHER: "${KRATOS_SECRETS_CIPHER}"
    ports:
      - "4433:4433"  # Public API
      - "4434:4434"  # Admin API
    volumes:
      - ./.vibewarden/generated/kratos:/etc/kratos:ro
    networks:
      - vibewarden
    depends_on:
      kratos-db:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "kratos", "ping", "--endpoint", "http://localhost:4433"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
{{- end }}
{{- if .Secrets.Enabled }}

  openbao:
    image: quay.io/openbao/openbao:2.2.0
    restart: unless-stopped
    cap_add:
      - IPC_LOCK
    env_file:
      - ./.vibewarden/generated/.credentials
    environment:
      BAO_DEV_ROOT_TOKEN_ID: ${OPENBAO_DEV_ROOT_TOKEN}
      BAO_DEV_LISTEN_ADDRESS: "0.0.0.0:8200"
    ports:
      - "8200:8200"
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD-SHELL", "BAO_ADDR=http://127.0.0.1:8200 bao status"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 5s
{{- end }}
{{- if and .Secrets.Enabled (or (len .Secrets.Inject.Headers) (len .Secrets.Inject.Env)) }}

  seed-secrets:
    image: quay.io/openbao/openbao:2.2.0
    env_file:
      - ./.vibewarden/generated/.credentials
    environment:
      BAO_ADDR: http://openbao:8200
      BAO_TOKEN: ${OPENBAO_DEV_ROOT_TOKEN}
    volumes:
      - ./.vibewarden/generated/seed-secrets.sh:/seed-secrets.sh:ro
      - ./.vibewarden/generated/.credentials:/.credentials:ro
    entrypoint: sh
    command: /seed-secrets.sh
    depends_on:
      openbao:
        condition: service_healthy
    networks:
      - vibewarden
    restart: "no"
{{- end }}
{{- if .Auth.Enabled }}

  seed-users:
    image: curlimages/curl:8.12.1
    environment:
      KRATOS_ADMIN_URL: http://kratos:4434
    volumes:
      - ./scripts/seed-users.sh:/seed-users.sh:ro
    command: sh /seed-users.sh
    depends_on:
      kratos:
        condition: service_healthy
    networks:
      - vibewarden
    restart: "no"
{{- end }}
{{- if eq .RateLimit.Store "redis" }}

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: ["redis-server", "--appendonly", "yes"]
    volumes:
      - redis-data:/data
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{{- end }}
{{- if .Observability.Enabled }}

  prometheus:
    image: prom/prometheus:v3.2.1
    profiles:
      - observability
    restart: unless-stopped
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/usr/share/prometheus/console_libraries'
      - '--web.console.templates=/usr/share/prometheus/consoles'
    ports:
      - "{{ .Observability.PrometheusPort }}:9090"
    volumes:
      - ./.vibewarden/generated/observability/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:9090/-/healthy"]
      interval: 10s
      timeout: 5s
      retries: 5

  loki:
    image: grafana/loki:3.4.3
    profiles:
      - observability
    restart: unless-stopped
    command: -config.file=/etc/loki/loki-config.yml
    ports:
      - "{{ .Observability.LokiPort }}:3100"
    volumes:
      - ./.vibewarden/generated/observability/loki/loki-config.yml:/etc/loki/loki-config.yml:ro
      - loki-data:/loki
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3100/ready || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5

  promtail:
    image: grafana/promtail:3.4.3
    profiles:
      - observability
    restart: unless-stopped
    command: -config.file=/etc/promtail/promtail-config.yml
    volumes:
      - ./.vibewarden/generated/observability/promtail/promtail-config.yml:/etc/promtail/promtail-config.yml:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    networks:
      - vibewarden
    depends_on:
      loki:
        condition: service_healthy

  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.123.0
    profiles:
      - observability
    restart: unless-stopped
    command: ["--config=/etc/otelcol-contrib/config.yaml"]
    volumes:
      - ./.vibewarden/generated/observability/otel-collector/config.yaml:/etc/otelcol-contrib/config.yaml:ro
    networks:
      - vibewarden
    depends_on:
      loki:
        condition: service_healthy
      tempo:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:13133/"]
      interval: 10s
      timeout: 5s
      retries: 5

  tempo:
    image: grafana/tempo:2.7.2
    profiles:
      - observability
    restart: unless-stopped
    command: ["-config.file=/etc/tempo/tempo-config.yml"]
    volumes:
      - ./.vibewarden/generated/observability/tempo/tempo-config.yml:/etc/tempo/tempo-config.yml:ro
      - tempo-data:/var/tempo
    networks:
      - vibewarden
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3200/ready || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5

  grafana:
    image: grafana/grafana:11.5.2
    profiles:
      - observability
    restart: unless-stopped
    env_file:
      - ./.vibewarden/generated/.credentials
    environment:
      GF_AUTH_ANONYMOUS_ENABLED: "true"
      GF_AUTH_ANONYMOUS_ORG_ROLE: "Admin"
      GF_AUTH_DISABLE_LOGIN_FORM: "true"
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_ADMIN_PASSWORD}
    ports:
      - "{{ .Observability.GrafanaPort }}:3000"
    volumes:
      - ./.vibewarden/generated/observability/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./.vibewarden/generated/observability/grafana/dashboards:/var/lib/grafana/dashboards:ro
      - grafana-data:/var/lib/grafana
    networks:
      - vibewarden
    depends_on:
      prometheus:
        condition: service_healthy
      loki:
        condition: service_healthy
      otel-collector:
        condition: service_healthy
      tempo:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:3000/api/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
{{- end }}

networks:
  vibewarden:
    driver: bridge
{{- if or .Auth.Enabled .TLS.Enabled (eq .RateLimit.Store "redis") .Observability.Enabled }}

volumes:
{{- if .Auth.Enabled }}
  kratos-db-data:
{{- end }}
{{- if .TLS.Enabled }}
  vibewarden-data:
{{- end }}
{{- if eq .RateLimit.Store "redis" }}
  redis-data:
{{- end }}
{{- if .Observability.Enabled }}
  prometheus-data:
  loki-data:
  grafana-data:
  tempo-data:
{{- end }}
{{- end }}
